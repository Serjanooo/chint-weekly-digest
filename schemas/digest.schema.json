{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["title_options", "stories"],
  "properties": {
    "title_options": {"type": "array", "minItems": 10, "maxItems": 10, "items": {"type": "string", "minLength": 3}},
    "stories": {
      "type": "array", "minItems": 8, "maxItems": 8,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["candidate_id", "text", "link_text", "story_role", "source", "url", "published_date"],
        "properties": {
          "candidate_id": {"type": "string"},
          "text": {"type": "string", "minLength": 40},
          "link_text": {"type": "string", "minLength": 2},
          "story_role": {"type": "string", "enum": ["core", "entertaining"]},
          "source": {"type": "string"},
          "url": {"type": "string"},
          "published_date": {"type": "string"}
        }
      }
    }
  }
}
